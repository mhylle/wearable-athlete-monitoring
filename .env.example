# ─── Database ────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://wearable:wearable@db:5432/wearable

# ─── Redis ───────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Open Wearables ─────────────────────────────────────
OW_API_URL=http://ow-backend:8000
OW_API_KEY=dev-api-key
OW_SECRET_KEY=ow-dev-secret

# ─── JWT Authentication ─────────────────────────────────
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# ─── Sync ──────────────────────────────────────────────
SYNC_INTERVAL_MINUTES=60

# ─── Application ────────────────────────────────────────
DEBUG=true
APP_VERSION=0.1.0
